---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CharacterCard from '../../components/CharacterCard.astro';
import ItemListSchema from '../../components/ItemListSchema.astro';
import BreadcrumbSchema from '../../components/BreadcrumbSchema.astro';

const characters = await getCollection('characters');

// 角色数据（元素、命途）
const characterData: Record<string, { rarity: number; element: string; path: string }> = {
  kafka: { rarity: 5, element: 'Lightning', path: 'Nihility' },
  acheron: { rarity: 5, element: 'Lightning', path: 'Nihility' },
  firefly: { rarity: 5, element: 'Fire', path: 'Destruction' },
  'dan-heng-imbibitor-lunae': { rarity: 5, element: 'Imaginary', path: 'Destruction' },
  blade: { rarity: 5, element: 'Wind', path: 'Destruction' },
  'jing-yuan': { rarity: 5, element: 'Lightning', path: 'Erudition' },
  seele: { rarity: 5, element: 'Quantum', path: 'Hunt' },
  'silver-wolf': { rarity: 5, element: 'Quantum', path: 'Nihility' },
  'fu-xuan': { rarity: 5, element: 'Quantum', path: 'Preservation' },
  'ruan-mei': { rarity: 5, element: 'Ice', path: 'Harmony' },
  robin: { rarity: 5, element: 'Physical', path: 'Harmony' },
  sparkle: { rarity: 5, element: 'Quantum', path: 'Harmony' },
  'black-swans': { rarity: 5, element: 'Wind', path: 'Nihility' },
  aventurine: { rarity: 5, element: 'Imaginary', path: 'Preservation' },
  boothill: { rarity: 5, element: 'Physical', path: 'Hunt' },
  gallagher: { rarity: 4, element: 'Fire', path: 'Abundance' },
  'harmony-mc': { rarity: 4, element: 'Imaginary', path: 'Harmony' },
  'march-7th': { rarity: 4, element: 'Ice', path: 'Preservation' },
  trailblazer: { rarity: 4, element: 'Physical', path: 'Destruction' },
};

// 按稀有度排序
const sortedCharacters = characters.sort((a, b) => {
  const dataA = characterData[a.id] || { rarity: 4 };
  const dataB = characterData[b.id] || { rarity: 4 };
  return dataB.rarity - dataA.rarity;
});

// 准备 ItemList 数据
const itemList = sortedCharacters.map(char => ({
  name: char.data.character,
  url: `/characters/${char.id}`,
  description: char.data.description,
}));
---

<BaseLayout title="Characters | GameBeliever" description="Browse all Honkai Star Rail characters with detailed guides, builds, and team recommendations.">
  <Navbar />

  <ItemListSchema
    name="Honkai Star Rail Characters"
    description="Complete list of all Honkai Star Rail characters with detailed guides, builds, and team recommendations."
    items={itemList}
  />

  <BreadcrumbSchema items={[
    { name: 'Home', url: '/' },
    { name: 'Characters', url: '/characters' },
  ]} />

  <main class="container mx-auto px-4 py-8">
    <!-- Page Header -->
    <div class="mb-8">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">Characters</h1>
      <p class="text-gray-400 text-lg">Browse all {characters.length} characters with detailed guides, builds, and team recommendations.</p>
    </div>

    <!-- Character Grid -->
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-6">
      {sortedCharacters.map(character => {
        const data = characterData[character.id] || { rarity: 5, element: 'Unknown', path: 'Unknown' };
        return (
          <CharacterCard
            name={character.data.character}
            slug={character.id}
            rarity={data.rarity}
            element={data.element}
            path={data.path}
          />
        );
      })}
    </div>
  </main>

  <Footer />
</BaseLayout>
