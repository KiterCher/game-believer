---
// Popular Builds 组件
const popularBuilds = [
  { name: 'Kafka', slug: 'kafka', role: 'DoT DPS', element: 'Lightning', tier: 'S' },
  { name: 'Acheron', slug: 'acheron', role: 'Hypercarry', element: 'Lightning', tier: 'S' },
  { name: 'Firefly', slug: 'firefly', role: 'Break DPS', element: 'Fire', tier: 'S' },
  { name: 'Dan Heng IL', slug: 'dan-heng-imbibitor-lunae', role: 'Hypercarry', element: 'Imaginary', tier: 'A' },
  { name: 'Black Swan', slug: 'black-swans', role: 'DoT DPS', element: 'Wind', tier: 'A' },
  { name: 'Ruan Mei', slug: 'ruan-mei', role: 'Support', element: 'Ice', tier: 'S' },
];

const elementColors: Record<string, string> = {
  Lightning: 'text-yellow-400',
  Fire: 'text-orange-500',
  Wind: 'text-green-400',
  Imaginary: 'text-orange-400',
  Ice: 'text-sky-400',
  Quantum: 'text-purple-400',
  Physical: 'text-gray-300',
};
---

<div class="bg-dark-200 rounded-xl p-6 border border-gray-800">
  <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
    <span class="text-2xl">⚔️</span>
    Popular Builds
  </h2>

  <div class="space-y-3">
    {popularBuilds.map((build, index) => (
      <a
        href={`/builds/${build.slug}`}
        class="group flex items-center gap-4 p-3 bg-dark-100 rounded-lg hover:bg-primary/20 hover:border-primary border border-transparent transition-all"
      >
        {/* Rank */}
        <span class="text-lg font-bold text-gray-600 w-6 text-center">
          {index + 1}
        </span>

        {/* Info */}
        <div class="flex-1">
          <div class="flex items-center gap-2">
            <h3 class="text-white font-bold group-hover:text-primary transition-colors">
              {build.name}
            </h3>
            <span class={`text-xs ${elementColors[build.element]}`}>
              {build.element}
            </span>
          </div>
          <p class="text-xs text-gray-500">{build.role}</p>
        </div>

        {/* Tier Badge */}
        <span class={`px-2 py-1 rounded text-xs font-bold ${
          build.tier === 'S' ? 'bg-yellow-500/20 text-yellow-400' :
          build.tier === 'A' ? 'bg-orange-500/20 text-orange-400' :
          'bg-blue-500/20 text-blue-400'
        }`}>
          {build.tier}
        </span>
      </a>
    ))}
  </div>

  <div class="mt-6 pt-4 border-t border-gray-800">
    <a href="/builds" class="text-primary hover:text-red-400 text-sm font-medium transition-colors">
      View All Builds →
    </a>
  </div>
</div>
