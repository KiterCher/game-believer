---
// Current Banner 组件
const currentBanner = {
  version: '2.3',
  phase: 1,
  characters: [
    { name: 'Firefly', slug: 'firefly', rarity: 5, element: 'Fire', path: 'Destruction' },
    { name: 'Ruan Mei', slug: 'ruan-mei', rarity: 5, element: 'Ice', path: 'Harmony' },
  ],
  startDate: '2026-06-19',
  endDate: '2026-07-09',
};

const nextBanner = {
  version: '2.3',
  phase: 2,
  characters: [
    { name: 'Black Swan', slug: 'black-swans', rarity: 5, element: 'Wind', path: 'Nihility' },
    { name: 'Argenti', slug: 'argenti', rarity: 5, element: 'Physical', path: 'Erudition' },
  ],
  startDate: '2026-07-09',
};

// 计算剩余天数
const now = new Date();
const endDate = new Date(currentBanner.endDate);
const daysLeft = Math.max(0, Math.ceil((endDate.getTime() - now.getTime()) / (1000 * 60 * 60 * 24)));
---

<div class="bg-dark-200 rounded-xl p-6 border border-gray-800">
  <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
    <img src="/images/icons/quest.png" alt="" class="w-6 h-6" />
    Current Banner
  </h2>

  {/* 当前卡池 */}
  <div class="mb-6">
    <div class="flex items-center justify-between mb-4">
      <span class="text-sm text-gray-400">Version {currentBanner.version} - Phase {currentBanner.phase}</span>
      <span class="px-3 py-1 bg-primary/20 text-primary rounded-full text-sm font-medium">{daysLeft} days left</span>
    </div>

    <div class="grid grid-cols-2 gap-4">
      {currentBanner.characters.map(char => (
        <a
          href={`/pull-advice/${char.slug}`}
          class="character-card group relative overflow-visible rounded-xl bg-dark-100 border border-gray-700 hover:border-primary transition-all"
        >
          <div class="relative pt-4 px-2">
            {/* 角色图片 - 延伸到卡片外部 */}
            <div class="relative -mt-16 mb-4">
              <img
                src={`/images/characters/${char.slug}/full.webp`}
                alt={char.name}
                class="character-img w-full h-64 object-cover object-top rounded-lg"
                loading="lazy"
                onerror="this.src='/images/characters/${char.slug}/card.webp'"
              />
              {/* 元素标签 */}
              <div class="absolute top-2 left-2 px-2 py-1 rounded bg-dark-300/90 backdrop-blur-sm">
                <span class="text-xs text-white font-medium">{char.element}</span>
              </div>
              {/* 稀有度标签 */}
              <div class="absolute top-2 right-2 px-2 py-1 rounded bg-yellow-500/90 backdrop-blur-sm">
                <span class="text-xs text-white font-bold">{char.rarity}★</span>
              </div>
            </div>
            {/* 角色信息 */}
            <div class="text-center pb-2">
              <h3 class="text-white font-bold group-hover:text-primary transition-colors">{char.name}</h3>
              <p class="text-xs text-gray-500">{char.path}</p>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>

  {/* 下期卡池 */}
  <div class="pt-4 border-t border-gray-800">
    <div class="flex items-center justify-between mb-3">
      <span class="text-sm text-gray-400">Next: Version {nextBanner.version} - Phase {nextBanner.phase}</span>
      <span class="text-xs text-gray-500">Starts {nextBanner.startDate}</span>
    </div>

    <div class="flex gap-2">
      {nextBanner.characters.map(char => (
        <a
          href={`/pull-advice/${char.slug}`}
          class="group flex items-center gap-2 px-3 py-2 bg-dark-100 rounded-lg hover:bg-primary/20 transition-all"
        >
          <div class="w-8 h-8 rounded-full overflow-hidden">
            <img
              src={`/images/characters/${char.slug}/card.webp`}
              alt={char.name}
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <span class="text-xs text-gray-400 group-hover:text-white transition-colors">{char.name}</span>
        </a>
      ))}
    </div>
  </div>

  <div class="mt-4">
    <a href="/banners" class="text-primary hover:text-red-400 text-sm font-medium transition-colors">
      View All Banners →
    </a>
  </div>
</div>
