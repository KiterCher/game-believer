---
// Current Banner 组件
const currentBanner = {
  version: '2.3',
  phase: 1,
  characters: [
    { name: 'Firefly', slug: 'firefly', rarity: 5, element: 'Fire', path: 'Destruction' },
    { name: 'Ruan Mei', slug: 'ruan-mei', rarity: 5, element: 'Ice', path: 'Harmony' },
  ],
  startDate: '2026-06-19',
  endDate: '2026-07-09',
};

const nextBanner = {
  version: '2.3',
  phase: 2,
  characters: [
    { name: 'Black Swan', slug: 'black-swans', rarity: 5, element: 'Wind', path: 'Nihility' },
    { name: 'Argenti', slug: 'argenti', rarity: 5, element: 'Physical', path: 'Erudition' },
  ],
  startDate: '2026-07-09',
};

// 计算剩余天数
const now = new Date();
const endDate = new Date(currentBanner.endDate);
const daysLeft = Math.max(0, Math.ceil((endDate.getTime() - now.getTime()) / (1000 * 60 * 60 * 24)));
---

<div class="bg-dark-200 rounded-xl p-6 border border-gray-800">
  <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
    <span class="text-2xl">🎯</span>
    Current Banner
  </h2>

  {/* 当前卡池 */}
  <div class="mb-6">
    <div class="flex items-center justify-between mb-4">
      <span class="text-sm text-gray-400">Version {currentBanner.version} - Phase {currentBanner.phase}</span>
      <span class="text-sm text-primary font-medium">{daysLeft} days left</span>
    </div>

    <div class="grid grid-cols-2 gap-4">
      {currentBanner.characters.map(char => (
        <a
          href={`/pull-advice/${char.slug}`}
          class="group p-4 bg-dark-100 rounded-lg hover:bg-primary/20 hover:border-primary border border-transparent transition-all"
        >
          <div class="text-center">
            <div class="w-16 h-16 mx-auto mb-2 rounded-full bg-dark-300 flex items-center justify-center">
              <span class="text-2xl font-bold text-gray-600">{char.name[0]}</span>
            </div>
            <h3 class="text-white font-bold group-hover:text-primary transition-colors">{char.name}</h3>
            <p class="text-xs text-gray-500">{char.rarity}★ {char.element} {char.path}</p>
          </div>
        </a>
      ))}
    </div>
  </div>

  {/* 下期卡池 */}
  <div class="pt-4 border-t border-gray-800">
    <div class="flex items-center justify-between mb-3">
      <span class="text-sm text-gray-400">Next: Version {nextBanner.version} - Phase {nextBanner.phase}</span>
      <span class="text-xs text-gray-500">Starts {nextBanner.startDate}</span>
    </div>

    <div class="flex gap-2">
      {nextBanner.characters.map(char => (
        <span class="px-3 py-1 bg-dark-100 rounded-full text-xs text-gray-400">
          {char.name}
        </span>
      ))}
    </div>
  </div>

  <div class="mt-4">
    <a href="/banners" class="text-primary hover:text-red-400 text-sm font-medium transition-colors">
      View All Banners →
    </a>
  </div>
</div>
