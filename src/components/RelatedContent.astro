---
export interface Props {
  currentSlug: string;
  currentType: string;
}

const { currentSlug, currentType } = Astro.props;

const relatedLinks = [
  { type: 'characters', label: 'Character Guide', icon: '/images/icons/avatar.png' },
  { type: 'builds', label: 'Build Guide', icon: '/images/icons/inventory.png' },
  { type: 'teams', label: 'Team Guide', icon: '/images/icons/team.png' },
  { type: 'pull-advice', label: 'Pull Advice', icon: '/images/icons/shop.png' },
].filter(link => link.type !== currentType);
---

<div class="sticky top-20 p-4 bg-[#1a1a1a] rounded-lg border border-[#333]">
  <h4 class="text-white font-bold mb-4 text-sm uppercase tracking-wider">Related Guides</h4>
  <ul class="space-y-3">
    {relatedLinks.map(link => (
      <li>
        <a
          href={`/${link.type}/${currentSlug}`}
          class="flex items-center gap-3 p-2 rounded hover:bg-[#2a2a2a] transition-colors group"
        >
          <img src={link.icon} alt="" class="w-5 h-5" />
          <span class="text-sm text-[#999] group-hover:text-white transition-colors">{link.label}</span>
        </a>
      </li>
    ))}
  </ul>
</div>
