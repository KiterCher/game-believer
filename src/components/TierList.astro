---
// Tier List 组件
const tiers = [
  {
    rank: 'S',
    color: 'bg-gradient-to-r from-yellow-500 to-amber-500',
    textColor: 'text-yellow-400',
    borderColor: 'border-yellow-500',
    characters: [
      { name: 'Kafka', slug: 'kafka', role: 'DoT DPS', element: 'Lightning' },
      { name: 'Acheron', slug: 'acheron', role: 'Hypercarry', element: 'Lightning' },
      { name: 'Firefly', slug: 'firefly', role: 'Break DPS', element: 'Fire' },
      { name: 'Ruan Mei', slug: 'ruan-mei', role: 'Support', element: 'Ice' },
    ],
  },
  {
    rank: 'A',
    color: 'bg-gradient-to-r from-orange-500 to-red-500',
    textColor: 'text-orange-400',
    borderColor: 'border-orange-500',
    characters: [
      { name: 'Dan Heng IL', slug: 'dan-heng-imbibitor-lunae', role: 'Hypercarry', element: 'Imaginary' },
      { name: 'Black Swan', slug: 'black-swans', role: 'DoT DPS', element: 'Wind' },
      { name: 'Sparkle', slug: 'sparkle', role: 'Support', element: 'Quantum' },
      { name: 'Robin', slug: 'robin', role: 'Support', element: 'Physical' },
    ],
  },
  {
    rank: 'B',
    color: 'bg-gradient-to-r from-blue-500 to-cyan-500',
    textColor: 'text-blue-400',
    borderColor: 'border-blue-500',
    characters: [
      { name: 'Blade', slug: 'blade', role: 'DPS', element: 'Wind' },
      { name: 'Jing Yuan', slug: 'jing-yuan', role: 'AoE DPS', element: 'Lightning' },
      { name: 'Seele', slug: 'seele', role: 'Single-T DPS', element: 'Quantum' },
      { name: 'Fu Xuan', slug: 'fu-xuan', role: 'Tank', element: 'Quantum' },
    ],
  },
];

const elementColors: Record<string, string> = {
  Lightning: 'bg-yellow-500/20 text-yellow-400',
  Fire: 'bg-orange-500/20 text-orange-400',
  Wind: 'bg-green-500/20 text-green-400',
  Imaginary: 'bg-orange-400/20 text-orange-300',
  Ice: 'bg-sky-500/20 text-sky-400',
  Quantum: 'bg-purple-500/20 text-purple-400',
  Physical: 'bg-gray-400/20 text-gray-300',
};
---

<div class="bg-dark-200 rounded-xl p-6 border border-gray-800">
  <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
    <img src="/images/icons/achievement.png" alt="" class="w-6 h-6" />
    Tier List
  </h2>

  <div class="space-y-4">
    {tiers.map(tier => (
      <div class="flex items-center gap-4">
        {/* Tier Rank Badge */}
        <div class={`w-12 h-12 rounded-xl ${tier.color} flex items-center justify-center flex-shrink-0 shadow-lg`}>
          <span class="text-white font-black text-xl drop-shadow-md">{tier.rank}</span>
        </div>

        {/* Character Avatars - 小圆形头像 */}
        <div class="flex-1 flex items-center gap-2 flex-wrap">
          {tier.characters.map(char => (
            <a
              href={`/characters/${char.slug}`}
              class="group relative"
            >
              <div class="w-12 h-12 rounded-full overflow-hidden border-2 border-gray-700 group-hover:border-primary transition-all group-hover:scale-110 group-hover:shadow-[0_0_15px_rgba(229,57,53,0.5)]">
                <img
                  src={`/images/characters/${char.slug}/card.webp`}
                  alt={char.name}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </div>
              {/* Tooltip */}
              <div class="absolute -bottom-8 left-1/2 -translate-x-1/2 bg-dark-300 px-2 py-1 rounded text-xs text-white whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-10">
                {char.name}
              </div>
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>

  <div class="mt-6 pt-4 border-t border-gray-800">
    <a href="/tier-list" class="text-primary hover:text-red-400 text-sm font-medium transition-colors">
      View Full Tier List →
    </a>
  </div>
</div>
