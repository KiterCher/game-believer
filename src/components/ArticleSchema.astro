---
export interface Props {
  title: string;
  description: string;
  url: string;
  image?: string;
  datePublished: string;
  dateModified?: string;
  author?: string;
}

const {
  title,
  description,
  url,
  image = '/og-default.png',
  datePublished,
  dateModified = datePublished,
  author = 'GameBeliever',
} = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "image": new URL(image, Astro.site).href,
  "url": new URL(url, Astro.site).href,
  "datePublished": datePublished,
  "dateModified": dateModified,
  "author": {
    "@type": "Organization",
    "name": author,
    "url": Astro.site?.href
  },
  "publisher": {
    "@type": "Organization",
    "name": "GameBeliever",
    "url": Astro.site?.href
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": new URL(url, Astro.site).href
  }
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
