---
export interface Props {
  headings: {
    depth: number;
    slug: string;
    text: string;
  }[];
}

const { headings } = Astro.props;

// Filter to only show h2 and h3
const filteredHeadings = headings.filter(h => h.depth >= 2 && h.depth <= 3);
---

{filteredHeadings.length > 0 && (
  <nav class="sticky top-20 p-4 bg-[#1a1a1a] rounded-lg border border-[#333]">
    <h4 class="text-white font-bold mb-4 text-sm uppercase tracking-wider">Table of Contents</h4>
    <ul class="space-y-2">
      {filteredHeadings.map(heading => (
        <li>
          <a
            href={`#${heading.slug}`}
            class={`block text-sm transition-colors hover:text-[#E53935] ${
              heading.depth === 2 ? 'text-white font-medium' : 'text-[#999] pl-4'
            }`}
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}
