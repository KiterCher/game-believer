# AI API Configuration
AI_PROVIDER=Mimo
AI_API_KEY=your-api-key-here
AI_MODEL=mimo-v2.5
AI_BASE_URL=https://api.xiaomimimo.com/v1

# Google Analytics (替换为你的 GA4 Measurement ID)
# 格式: G-XXXXXXXXXX
PUBLIC_GA_ID=

# Google Search Console Verification (替换为你的验证码)
# 从 https://search.google.com/search-console 获取
PUBLIC_GSC_VERIFICATION=

# Bing Webmaster Verification (替换为你的验证码)
# 从 https://www.bing.com/webmasters 获取
PUBLIC_BING_VERIFICATION=

# Site URL
PUBLIC_SITE_URL=https://gamebeliever.com
